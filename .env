# ============================================================
#  DataMarketplace Bot — Environment Configuration
#  Copy this file to .env and fill in your values
# ============================================================

# --- Your Wallet ---
# The private key of the MetaMask wallet the bot will act as
# ⚠️  NEVER commit this file — it's in .gitignore
PRIVATE_KEY=0x682aff8551d9e183810f640ca98f8005b1ffd00505578bedb0b6af908199a9fe

# --- Network (Sepolia testnet) ---
# HTTP RPC for sending transactions
RPC_HTTP=https://sepolia.infura.io/v3/4e7e6d1b91644fd0b95caa29fce86ab3
ALTERNATE_RPC_HTTP=https://sepolia.infura.io/v3/6426761d274542bb9652e9a5aff35a0c

# WebSocket RPC for listening to events (same project, ws endpoint)
RPC_WS=wss://sepolia.infura.io/ws/v3/4e7e6d1b91644fd0b95caa29fce86ab3

# Chain ID for Sepolia
CHAIN_ID=11155111

# --- Contract Addresses (from factory.js / socketFactory.js) ---
# Primary deployed factory (used in factory.js)
FACTORY_ADDRESS=0xb61Cd17D498f82E9F22771254C31bCBBb5781540

# Socket factory address (used in socketFactory.js for event listening)
FACTORY_SOCKET_ADDRESS=0xCf77A40535908Ae58c687A4A77D21259822968B8

# --- Bot Mode ---
# simulate  → read-only, logs what it would do
# buy       → bid on auctions that meet criteria
# sell      → create new auctions (list your data)
# auto      → buy + sell on a cron schedule
# status    → print a full snapshot of all auctions and your wallet
BOT_MODE=auto

# --- Bidding Strategy ---
# Maximum total bid the bot will ever place on a single auction (in Wei)
MAX_BID_WEI=5000

# How much to outbid the current highest bid by (in Wei)
OUTBID_BY_WEI=100

# Only bid on auctions whose minimum contribution is <= this (Wei)
MAX_MIN_CONTRIBUTION_WEI=2000

# Skip auctions where you are already the highest bidder
SKIP_IF_WINNING=false

# Only bid on auctions with time remaining above this threshold (seconds)
MIN_TIME_REMAINING_SEC=60

# --- Creating Auctions (sell mode) ---
# Auctions to create are defined in data/sell-list.json

# --- Auto-trade cron schedule (default: every 2 minutes) ---
AUTO_TRADE_CRON=*/2 * * * *

# --- Misc ---
LOG_LEVEL=info

TRADING_PROFILE=balanced
AUTO_CREATE_AUCTIONS=true
ENABLE_BIDDING=true
ENABLE_SELLING=true
ENABLE_FINALIZE=true

AUTO_GENERATE_AUCTIONS=true
AUTO_GENERATE_COUNT=2

TARGET_ACTIVE_SELL_AUCTIONS=2

MAX_TOTAL_SELL_AUCTIONS=2
